---
const heading = "About me";

const paragraphs = [
  "I'm currently a 4th year student studying BS in Computer Science at the University of the Philippines Tacloban. Somewhere along the way I got curious about how the websites and apps I use every day actually work, and that curiosity turned into learning to code.",
  "Right now I'm mainly working with websites, and I'm especially drawn to full-stack development. Most of what I know so far has come from developing course projects.",
  "Outside of coding, I play games. I'm currently learning emerging technologies."
];
---

<section id="about-me" class="about-me">
  <div class="title">
    <h2>{heading}</h2>
  </div>

  <div class="about-body">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<style>
  .about-me {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(60px, 10vw, 120px) 24px;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 64px;
  }

  .title {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #f8fafc;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 3px solid white;
    padding-bottom: 12px;
    display: inline-block;
  }

  .about-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-body p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #cbd5e1;
    margin: 0;
  }

  @media (max-width: 900px) {
    .about-me {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .title {
      position: relative;
      top: 0;
    }
  }
</style>