---
import { Image } from "astro:assets";
import profilePhoto from "../assets/profile.jpg";

const name = "Jhun Kenneth Iniego";
const role = "Software Developer";
const tagline = "I build clean, engaging interfaces!";

const socials = [
  {
    name: "GitHub",
    url: "https://github.com/JKIniego",
    icon: '<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>',
  },
  {
    name: "LinkedIn",
    url: "https://linkedin.com/in/jhun-kenneth-iniego-3a266738b",
    icon: '<path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>',
  }
];
---

<header id="hero" class="hero">
  <div class="hero-content">
    <span class="tag">
      <span class="tag-pulse"></span>
      {role}
    </span>

    <h1>
      Hi, I'm<br />
      <span>{name}</span>
    </h1>

    <p class="tagline">{tagline}</p>

    <a href="#projects" class="cta">
      See my work
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-circle-fill" viewBox="0 0 16 16">
        <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0M4.5 7.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5z"/>
      </svg>
    </a>

    <div class="socials">
      {socials.map(social => (
        <a href={social.url} class="social-link" aria-label={social.name} target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" set:html={social.icon} />
        </a>
      ))}
    </div>
  </div>

  <div class="hero-photo">
    <Image src={profilePhoto} alt={name} width={420} height={420} />
  </div>
</header>

<style>
  .hero {
    position: relative;
    padding: clamp(40px, 10vw, 80px) clamp(60px, 15vw, 220px) clamp(40px, 10vw, 100px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
    
    background-color: #080c16;
    background-image: 
      radial-gradient(circle at 0% 100%, rgba(99, 142, 241, 0.1) 0%, transparent 40%),
      radial-gradient(circle at 100% 100%, rgba(63, 244, 99, 0.1) 0%, transparent 40%);
  }

  .hero-content {
    flex: 1 1 380px;
    min-width: 0;
    max-width: 500px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #cbd5e1;
    background: #1e293b;
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 24px;
    border: 1px solid #334155;
  }

  .tag-pulse {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.5); }
    70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    color: #f8fafc;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
  }

  h1 span {
    background: linear-gradient(to right, #5fc4ff, #43ff78, #5fc4ff);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    display: inline;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    transition: filter 0.3s ease;
  }

  h1 span:hover {
    filter: drop-shadow(0px 4px 12px rgba(95, 196, 255, 0.75));
  }

  .tagline {
    font-size: 1.1rem;
    color: #cbd5e1;
    line-height: 1.65;
    max-width: 440px;
    margin-bottom: 36px;
    background: linear-gradient(180deg, #f8fafc 0%, #94a3b8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 1rem;
    color: #0b0f19;
    background-color: #f8fafc;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 12px;
    box-shadow: 0 4px 14px rgba(255, 255, 255, 0.1);
    transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    font-weight: 600;
  }

  .cta:hover {
    background-color: #e2e8f0;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 255, 255, 0.15);
  }

  .cta:active {
    transform: translateY(1px);
  }

  .cta svg {
    margin-left: 5px;
    transition: transform 0.15s ease;
  }

  .cta:hover svg {
    transform: translateX(3px);
  }

  .socials {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 32px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    border: 1px solid #1e293b;
    background: #0f172a;
    color: #94a3b8;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .social-link:hover {
    color: #f8fafc;
    border-color: #334155;
    background-color: #1e293b;
    transform: translateY(-4px);
    filter: drop-shadow(0 4px 12px rgba(255, 255, 255, 0.05));
  }

  .hero-photo {
    flex: 0 0 auto;
    width: clamp(160px, 22vw, 320px);
    height: clamp(160px, 22vw, 320px);
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid #1e293b;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.6);
  }

  .hero-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 90px 40px 175px;
      gap: 40px;
    }
  }

  @media (max-width: 720px) {
    .hero {
      flex-direction: column-reverse;
      text-align: center;
      padding: 70px 24px 140px;
    }

    .hero-content {
      max-width: none;
    }

    .tagline {
      max-width: none;
      margin-left: auto;
      margin-right: auto;
    }

    .socials {
      justify-content: center;
    }

    .hero-photo {
      width: clamp(140px, 40vw, 220px);
      height: clamp(140px, 40vw, 220px);
    }
  }
</style>