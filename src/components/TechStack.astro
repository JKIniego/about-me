---
import { Image } from "astro:assets";
import quasarIcon from "../assets/icons/Quasar.svg";

const heading = "Tech Stack";

const iconMap: Record<string, string> = {
  "HTML": "html",
  "CSS": "css",
  "JavaScript": "js",
  "React.js": "react",
  "Vue.js": "vue",
  "Quasar": "quasar",
  "Astro": "astro",
  "Java": "java",
  "Python": "python",
  "Django": "django",
  "Php": "php",
  "Laravel": "laravel",
  "MySQL": "mysql",
  "PostgreSQL": "postgres",
  "Supabase": "supabase",
  "Git": "git",
  "GitHub": "github",
  "Figma": "figma",
  "VS Code": "vscode"
};

const categories = [
  {
    label: "Frontend",
    items: ["HTML", "CSS", "JavaScript", "React.js", "Vue.js", "Quasar", "Astro"]
  },
  {
    label: "Backend & DB",
    items: ["Python", "Django", "Php", "Laravel", "MySQL", "PostgreSQL", "Supabase", "Java"]
  },
  {
    label: "Tools",
    items: ["Git", "GitHub", "Figma", "VS Code"]
  }
];
---

<section id="tech-stack" class="tech-stack">
  <div class="tech-stack-wrapper">
    <div class="title-container">
      <h2>{heading}</h2>
    </div>

    <div class="stack-groups">
      {categories.map((category) => (
        <div class="group">
          <span class="group-label">{category.label}</span>
          <div class="grid-container">
            {category.items.map((item) => (
              <div class="tech-card">
                <div class="icon-wrapper">
                  {item === "Quasar" ? (
                    <Image src={quasarIcon} alt="Quasar" width={20} height={20} />
                  ) : iconMap[item] ? (
                    <img
                      src={`https://skillicons.dev/icons?i=${iconMap[item]}`}
                      alt={item}
                      loading="lazy"
                      width="20"
                      height="20"
                    />
                  ) : (
                    <svg class="fallback-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 6 3 12l6 6" /><path d="M15 6l6 6-6 6" />
                    </svg>
                  )}
                </div>
                <span class="tech-name">{item}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-stack {
    padding: clamp(40px, 8vw, 120px) clamp(24px, 10vw, 180px);
    background-color: #080c16;
    box-sizing: border-box;
    width: 100%;
  }

  .tech-stack-wrapper {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
    width: 100%;
  }

  .title-container {
    width: 100%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding-bottom: 16px;
  }

  h2 {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 800;
    color: #f8fafc;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    position: relative;
    display: inline-block;
  }

  h2::after {
    content: "";
    position: absolute;
    bottom: -17px;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(to right, #3b82f6, #10b981, transparent);
    border-radius: 2px;
  }

  .stack-groups {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .group {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    align-items: flex-start;
  }

  .group-label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: white;
    padding-top: 4px;
  }
  
  .grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 16px;
  }
  
  .tech-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: linear-gradient(135deg, #0f172a 0%, #0d131f 100%);
    border: 1px solid #1e293b;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .tech-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 12px 24px -4px rgba(59, 130, 246, 0.15);
  }
  
  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: #080c16;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .icon-wrapper img, :global(.icon-wrapper img) {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .tech-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #cbd5e1;
    letter-spacing: 0.01em;
  }

  .tech-card:hover .tech-name {
    color: #f8fafc;
  }

  .fallback-icon {
    width: 20px;
    height: 20px;
    color: #64748b;
  }

  @media (max-width: 600px) {
    .tech-stack {
      padding: 40px 16px;
    }

    .tech-stack-wrapper {
      gap: 36px;
    }

    .group {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .grid-container {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 12px;
    }
  }
</style>