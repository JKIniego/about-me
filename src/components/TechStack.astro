---
const heading = "Tech Stack";

const categories = [
  {
    label: "Frontend",
    items: ["HTML", "CSS", "JavaScript", "React.js", "Vue.js", "Quasar", "Astro", "Java"]
  },
  {
    label: "Backend",
    items: ["Python", "Django", "Php", "Laravel", "MySQL", "PostgreSQL", "Supabase"]
  },
  {
    label: "Tools",
    items: ["Git", "GitHub", "Figma", "VS Code"]
  }
];
---

<section id="tech-stack" class="tech-stack">
  <div class="title">
    <h2>{heading}</h2>
  </div>

  <div class="stack-groups">
    {categories.map((category) => (
      <div class="group">
        <span class="group-label">{category.label}</span>
        <div class="pills">
          {category.items.map((item) => (
            <span class="pill">{item}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .tech-stack {
    padding: 90px 60px;
    background: #fff;
  }

  .title {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h2 {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 48px;
    text-transform: uppercase;
    border-bottom: 3px solid #1a1a1a;
  }

  .stack-groups {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .group {
    display: flex;
    gap: 24px;
    align-items: baseline;
  }

  .group-label {
    flex: 0 0 100px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #777;
  }

  .pills {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .pill {
    font-size: 0.9rem;
    font-weight: 500;
    color: #1a1a1a;
    padding: 6px 16px;
    border: 1px solid #e5e5e5;
    border-radius: 20px;
  }

  @media (max-width: 640px) {
    .tech-stack {
      padding: 60px 24px;
    }

    .group {
      flex-direction: column;
      gap: 10px;
    }

    .group-label {
      flex: none;
    }
  }
</style>