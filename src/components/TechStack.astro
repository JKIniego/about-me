---
import { Image } from "astro:assets";
import quasarIcon from "../assets/icons/Quasar.svg";

const heading = "Tech Stack";

const iconMap: Record<string, string> = {
  "HTML": "html",
  "CSS": "css",
  "JavaScript": "js",
  "React.js": "react",
  "Vue.js": "vue",
  "Quasar": "quasar",
  "Astro": "astro",
  "Java": "java",
  "Python": "python",
  "Django": "django",
  "Php": "php",
  "Laravel": "laravel",
  "MySQL": "mysql",
  "PostgreSQL": "postgres",
  "Supabase": "supabase",
  "Git": "git",
  "GitHub": "github",
  "Figma": "figma",
  "VS Code": "vscode"
};

const categories = [
  {
    label: "Frontend",
    items: ["HTML", "CSS", "JavaScript", "React.js", "Vue.js", "Quasar", "Astro"]
  },
  {
    label: "Backend & DB",
    items: ["Python", "Django", "Php", "Laravel", "MySQL", "PostgreSQL", "Supabase", "Java"]
  },
  {
    label: "Tools",
    items: ["Git", "GitHub", "Figma", "VS Code"]
  }
];
---

<section id="tech-stack" class="tech-stack">
  <div class="title">
    <h2>{heading}</h2>
  </div>

  <div class="stack-groups">
    {categories.map((category) => (
      <div class="group">
        <span class="group-label">{category.label}</span>
        <div class="grid-container">
          {category.items.map((item) => (
            <div class="tech-card">
              <div class="icon-wrapper">
                {item === "Quasar" ? (
                  <Image src={quasarIcon} alt="Quasar" width={20} height={20} />
                ) : iconMap[item] ? (
                  <img
                    src={`https://skillicons.dev/icons?i=${iconMap[item]}`}
                    alt={item}
                    loading="lazy"
                    width="20"
                    height="20"
                  />
                ) : (
                  <svg class="fallback-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 6 3 12l6 6" /><path d="M15 6l6 6-6 6" />
                  </svg>
                )}
              </div>
              <span class="tech-name">{item}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .tech-stack {
    padding: clamp(40px, 10vw, 135px) clamp(60px, 15vw, 220px);
    background-color: #080c16;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 64px;
  }

  .title {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #f8fafc;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 3px solid white;
    padding-bottom: 12px;
    display: inline-block;
  }

  .stack-groups {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .group {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 24px;
    align-items: flex-start;
  }

  .group-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: white;
    padding-top: 12px;
  }
  
  .grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 12px;
  }
  
  .tech-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .tech-card:hover {
    border-color: #468ee5;
    background: #131e36;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px -4px rgba(70, 142, 229, 0.15);
  }
  
  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: #080c16;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .icon-wrapper img, :global(.icon-wrapper img) {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .tech-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #cbd5e1;
    letter-spacing: 0.01em;
  }

  .tech-card:hover .tech-name {
    color: #f8fafc;
  }

  .fallback-icon {
    width: 20px;
    height: 20px;
    color: #64748b;
  }

  @media (max-width: 900px) {
    .tech-stack {
      padding: clamp(32px, 8vw, 80px) 40px;
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .title {
      position: relative;
      top: 0;
    }

    .group {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .group-label {
      padding-top: 0;
    }
  }

  @media (max-width: 720px) {
    .tech-stack {
      padding: clamp(28px, 6vw, 70px) 24px;
    }

    .grid-container {
      grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
      gap: 8px;
    }

    .tech-card {
      padding: 12px;
      gap: 8px;
    }
  }
</style>