---
import { Image } from "astro:assets";
import quasarIcon from "../assets/icons/Quasar.svg";

const heading = "Projects";

const codeLabels: Record<string, string> = {
  html: "HTML",
  css: "CSS",
  js: "JavaScript",
  react: "React.js",
  vue: "Vue.js",
  quasar: "Quasar",
  astro: "Astro",
  java: "Java",
  python: "Python",
  django: "Django",
  php: "PHP",
  laravel: "Laravel",
  mysql: "MySQL",
  postgres: "PostgreSQL",
  supabase: "Supabase"
};

const projects = [
  {
    title: "Wordle XL",
    description: "An extended version of Wordle built to guess 5+ lettered words and player statistics tracking",
    icons: "java",
    link: "https://github.com/JKIniego/wordle-xl"
  },
  {
    title: "IsSked",
    description: "A web-based class schedule maker that prompts the user to manually input their courses in a semester, which will be displayed as a table integrating task/assignment list for each course.",
    icons: "react,supabase",
    link: "https://github.com/JKIniego/IsSked"
  }
];
---

<section id="projects" class="projects">
  <div class="title">
    <h2>{heading}</h2>
  </div>

  <div class="project-grid">
    {projects.map((project) => (
      <div class="project-card">
        <div class="card-content">
          <div class="badges">
            {project.icons.split(",").map((code) => (
              <span class="badge">
                {codeLabels[code] === "Quasar" ? (
                  <Image src={quasarIcon} alt="Quasar" width={14} height={14} />
                ) : codeLabels[code] ? (
                  <img
                    src={`https://skillicons.dev/icons?i=${code}`}
                    alt={codeLabels[code]}
                    loading="lazy"
                  />
                ) : (
                  <svg class="fallback-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 6 3 12l6 6" /><path d="M15 6l6 6-6 6" />
                  </svg>
                )}
                {codeLabels[code]}
              </span>
            ))}
          </div>
          
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </div>

        <div class="button-container">
          <a href={project.link} target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
            <span>View in GitHub</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .projects {
    padding: clamp(40px, 10vw, 135px) clamp(60px, 15vw, 220px);
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 64px;
  }

  .title {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #f8fafc;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 3px solid white;
    padding-bottom: 12px;
    display: inline-block;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
  }

  .project-card {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 16px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.25);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-sizing: border-box;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: #334155;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4);
  }

  .project-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #f8fafc;
    margin: 0 0 12px;
  }

  .project-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #cbd5e1;
    margin: 0 0 24px;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #cbd5e1;
    background: #1e293b;
    padding: 4px 10px;
    border: 1px solid #334155;
    border-radius: 8px;
  }

  .badge img {
    width: 14px;
    height: 14px;
  }

  .fallback-icon {
    width: 14px;
    height: 14px;
    color: #64748b;
  }

  .button-container {
    width: 100%;
    display: flex;
    box-sizing: border-box;
    margin-top: 20px;
  }

  .button-container a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
    color: #f8fafc;
    background-color: #1e293b;
    border: 1px solid #334155;
    width: 100%;
    max-width: 100%;
    padding: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 10px;
    transition: all 0.2s ease;
    box-sizing: border-box;
  }

  .button-container a:hover {
    background-color: #334155;
    border-color: #475569;
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .projects {
      padding: clamp(32px, 8vw, 80px) 40px;
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .title {
      position: relative;
      top: 0;
    }
  }

  @media (max-width: 720px) {
    .projects {
      padding: clamp(28px, 6vw, 70px) 24px;
    }
  }
</style>