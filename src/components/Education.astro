---
const heading = "Education";

const entries = [
  {
    degree: "BS in Computer Science",
    institution: "University of the Philippines Tacloban",
    period: "2023 — Present"
  },
  {
    degree: "High School",
    institution: "Philippine Science High School - Eastern Visayas Campus",
    period: "2017 — 2023"
  },
  {
    degree: "Elementary",
    institution: "Rizal Central School",
    period: "2011 — 2017"
  }
];
---

<section id="education" class="education">
  <div class="title">
    <h2>{heading}</h2>
  </div>

  <div class="timeline">
    {entries.map(entry => (
      <div class="entry">
        <div class="entry-marker">
          <span class="dot"></span>
        </div>
        <div class="entry-content">
          <span class="entry-period">{entry.period}</span>
          <h3>{entry.degree}</h3>
          <p class="institution">{entry.institution}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .education {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(60px, 10vw, 120px) 24px;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 64px;
  }

  .title {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 3px solid #0f172a;
    padding-bottom: 12px;
    display: inline-block;
  }

  .timeline {
    position: relative;
    max-width: 680px;
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 9px;
    width: 2px;
    background: linear-gradient(to bottom, #468ee5, #e2e8f0 80%);
  }

  .entry {
    position: relative;
    display: flex;
    gap: 28px;
    padding-bottom: 40px;
  }

  .entry:last-child {
    padding-bottom: 0;
  }

  .entry-marker {
    position: relative;
    flex: 0 0 20px;
    display: flex;
    justify-content: center;
  }

  .dot {
    position: absolute;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #cbd5e1;
    box-shadow: 0 0 0 4px #ffffff;
    z-index: 1;
    transition: all 0.3s ease;
  }

  .entry-content {
    flex: 1;
    min-width: 0;
  }

  .entry-period {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #64748b;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }

  .entry-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 4px;
  }

  .institution {
    font-size: 0.95rem;
    font-weight: 500;
    color: #475569;
    margin: 0;
  }
  
  .entry:first-child .dot {
    background: #10b981;
    box-shadow: 0 0 0 5px #ffffff, 0 0 0 10px rgba(16, 185, 129, 0.15);
  }

  .entry:first-child .entry-period {
    color: #10b981;
  }

  @media (max-width: 900px) {
    .education {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .title {
      position: relative;
      top: 0;
    }
  }
</style>