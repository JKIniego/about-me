---
const heading = "Education";

const entries = [
  {
    degree: "BS in Computer Science",
    institution: "University of the Philippines Tacloban",
    period: "2023 — Present"
  },
  {
    degree: "High School",
    institution: "Philippine Science High School - Eastern Visayas Campus",
    period: "2017 — 2023"
  },
  {
    degree: "Elementary",
    institution: "Rizal Central School",
    period: "2011 — 2017"
  }
];
---

<section id="education" class="education">
  <div class="title">
    <h2>{heading}</h2>
  </div>

  <div class="timeline">
    {entries.map(entry => (
      <div class="entry">
        <div class="entry-marker">
          <span class="dot">
            <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8.211 2.047a.5.5 0 0 0-.422 0l-7.5 3.5a.5.5 0 0 0 .025.917l7.5 3a.5.5 0 0 0 .372 0L14 7.14V13a1 1 0 0 0-1 1v2h3v-2a1 1 0 0 0-1-1V6.739l.686-.275a.5.5 0 0 0 .025-.917z"/>
            </svg>
          </span>
        </div>
        <div class="entry-content">
          <span class="entry-period">{entry.period}</span>
          <h3>{entry.degree}</h3>
          <p class="institution">{entry.institution}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .education {
    padding: clamp(40px, 10vw, 135px) clamp(60px, 15vw, 220px);
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 64px;
    background: #0b0f19;
  }

  .title {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #f8fafc;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 3px solid white;
    padding-bottom: 12px;
    display: inline-block;
  }

  .timeline {
    position: relative;
    max-width: 680px;
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 9px;
    width: 2px;
    background: linear-gradient(to bottom, #3b82f6, #1e293b 90%);
  }

  .entry {
    position: relative;
    display: flex;
    gap: 28px;
    padding-bottom: 32px;
  }

  .entry:last-child {
    padding-bottom: 0;
  }

  .entry-marker {
    position: relative;
    flex: 0 0 20px;
    display: flex;
    justify-content: center;
  }

  .dot {
    position: absolute;
    top: 18px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #0b0f19;
    border: 2px solid #1e293b;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3b82f6;
    z-index: 1;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dot svg {
    opacity: 0;
    transform: scale(0.3);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .entry:hover .dot {
    background: #3b82f6;
    border-color: #3b82f6;
    color: #f8fafc;
    box-shadow: 0 0 0 4px #0b0f19, 0 0 12px rgba(59, 130, 246, 0.6);
    transform: scale(1.15);
  }

  .entry:hover .dot svg {
    opacity: 1;
    transform: scale(1);
  }

  .entry-content {
    flex: 1;
    min-width: 0;
    background: linear-gradient(135deg, #0f172a 0%, #0d131f 100%);
    border: 1px solid #1e293b;
    padding: 20px 24px;
    border-radius: 12px;
    backdrop-filter: blur(8px);
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .entry:hover .entry-content {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 12px 24px -4px rgba(59, 130, 246, 0.15);
  }

  .entry-period {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
    padding: 3px 8px;
    border-radius: 20px;
    letter-spacing: 0.05em;
    margin-bottom: 10px;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .entry:hover .entry-period {
    background: #3b82f6;
    color: #f8fafc;
  }

  .entry-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: #f8fafc;
    margin: 0 0 4px;
  }

  .institution {
    font-size: 0.95rem;
    font-weight: 500;
    color: #94a3b8;
    margin: 0;
    transition: color 0.25s ease;
  }

  .entry:hover .institution {
    color: #cbd5e1;
  }
  
  .entry:first-child .dot {
    border-color: #10b981;
    color: #10b981;
  }

  .entry:first-child:hover .dot {
    background: #10b981;
    border-color: #10b981;
    box-shadow: 0 0 0 4px #0b0f19, 0 0 12px rgba(16, 185, 129, 0.6);
  }

  .entry:first-child .entry-period {
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
  }

  .entry:first-child:hover .entry-period {
    background: #10b981;
    color: #f8fafc;
  }

  @media (max-width: 900px) {
    .education {
      padding: clamp(32px, 8vw, 80px) 40px;
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .title {
      position: relative;
      top: 0;
    }
  }

  @media (max-width: 720px) {
    .education {
      padding: clamp(28px, 6vw, 70px) 24px;
    }
    
    .entry-content {
      padding: 16px 20px;
    }
  }
</style>